# ── .dockerignore — SecureScope ──────────────────────────────────────────────
# Excludes files and directories that must NOT be copied into the Docker image.
# Keeps the build context small and prevents secrets leaking into the image.

# ── Git & CI ──────────────────────────────────────────────────────────────────
.git
.github
.gitignore

# ── Python bytecode & caches ──────────────────────────────────────────────────
__pycache__
*.pyc
*.pyo
*.pyd
*.egg-info
.eggs
dist
build
*.egg

# ── Virtual environments ──────────────────────────────────────────────────────
.venv
venv
env
ENV

# ── Scan output — never bake reports into the image ──────────────────────────
reports/
scan_target/

# ── Development / generator scripts (not needed at runtime) ──────────────────
gen_pdf_report.py
gen_sample.py
take_screenshots.py

# ── Docs & screenshots (runtime doesn't need them) ───────────────────────────
docs/
*.pdf

# ── Secrets & local config — never in the image ──────────────────────────────
.env
.env.*
*.key
*.pem
secrets.*

# ── IDE & OS noise ────────────────────────────────────────────────────────────
.vscode
.idea
*.DS_Store
Thumbs.db

# ── Test artefacts ────────────────────────────────────────────────────────────
.pytest_cache
.coverage
htmlcov/
